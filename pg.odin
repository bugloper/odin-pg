// package pg is a production-grade PostgreSQL client driver written in pure
// Odin — a native implementation of the PostgreSQL wire protocol (v3.0), with
// no dependency on libpq.
package pg

VERSION :: "0.1.0-dev"

// The wire protocol version spoken during startup: major 3, minor 0.
PROTOCOL_VERSION_MAJOR :: 3
PROTOCOL_VERSION_MINOR :: 0
